{
  "manifest_version": 3,
  "name": "Enviar pra Rádio Realce",
  "version": "2.2",
  "description": "Envia a música/vídeo/playlist do site atual (YouTube, SoundCloud, Suno, etc.) pro app Baixar Músicas — rádio ou Mac.",
  "permissions": ["activeTab", "tabs", "sidePanel", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8420/*",
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://soundcloud.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "popup.html" },
  "action": { "default_title": "Enviar pra Rádio Realce" }
}
